# LinkedFlow AI Server Settings
PORT=5000
NODE_ENV=development

# Google Gemini AI Studio Credentials
# Retrieve your key from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# GitHub Personal Access Token
GITHUB_PAT=YOUR_GITHUB_PAT_HERE

# LinkedIn Access Token
LINKEDIN_ACCESS_TOKEN=YOUR_LINKEDIN_ACCESS_TOKEN_HERE

# PostgreSQL Database Connection String
# e.g., postgresql://username:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linkedflow
